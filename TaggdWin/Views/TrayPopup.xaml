<Window x:Class="TaggdWin.Views.TrayPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        SizeToContent="Height" Width="360" TextOptions.TextFormattingMode="Ideal">

    <Grid Margin="10">
        <Border CornerRadius="16" Background="{StaticResource BackgroundBrush}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" Color="Black" />
            </Border.Effect>

            <StackPanel Margin="18,16">

                <!-- Header -->
                <Grid>
                    <TextBlock Text="TAGGED" VerticalAlignment="Center"
                               FontFamily="{StaticResource MonoFont}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CloudButton" Style="{StaticResource IconButton}" Click="OnOpenServer"
                                ToolTip="Open server in browser" Visibility="Collapsed" Margin="0,0,8,0">
                            <Path Data="{StaticResource Icon.Cloud}" Fill="{StaticResource TextPrimaryBrush}"
                                  Stretch="Uniform" Width="17" Height="17" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Click="OnOpenSettings" ToolTip="Settings">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </Button>
                        <Button Style="{StaticResource IconButton}" Click="OnQuit" ToolTip="Quit Tagged" Margin="8,0,0,0">
                            <TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Timer -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding HH}" FontFamily="{StaticResource MonoFont}" FontSize="46"
                                   FontWeight="Medium" Foreground="{Binding TimerBrush}" />
                        <TextBlock Text="h" FontFamily="{StaticResource MonoFont}" FontSize="20" Margin="1,0,8,4"
                                   VerticalAlignment="Bottom" Foreground="{Binding TimerUnitBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding MM}" FontFamily="{StaticResource MonoFont}" FontSize="46"
                                   FontWeight="Medium" Foreground="{Binding TimerBrush}" />
                        <TextBlock Text="m" FontFamily="{StaticResource MonoFont}" FontSize="20" Margin="1,0,8,4"
                                   VerticalAlignment="Bottom" Foreground="{Binding TimerUnitBrush}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding SS}" FontFamily="{StaticResource MonoFont}" FontSize="46"
                                   FontWeight="Medium" Foreground="{Binding TimerBrush}" />
                        <TextBlock Text="s" FontFamily="{StaticResource MonoFont}" FontSize="20" Margin="1,0,0,4"
                                   VerticalAlignment="Bottom" Foreground="{Binding TimerUnitBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Description -->
                <Border Style="{StaticResource Card}" Height="48" Margin="0,0,0,12">
                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <Grid Grid.Column="1">
                            <TextBox x:Name="DescriptionBox" Style="{StaticResource DarkTextBox}"
                                     FontSize="15" MaxLength="200"
                                     Text="{Binding TaskDescription, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="What are you working on?" IsHitTestVisible="False"
                                       VerticalAlignment="Center" Margin="3,0,0,0"
                                       FontFamily="{StaticResource MonoFont}" FontSize="15"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Visibility="{Binding TaskDescription, Converter={StaticResource EmptyToVis}}" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Tags -->
                <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="TAGS" VerticalAlignment="Center"
                                       FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Medium"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                            <Button HorizontalAlignment="Right" Style="{StaticResource IconButton}" Click="OnAddTag">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Text="Add" Margin="4,0,0,0" VerticalAlignment="Center"
                                               FontFamily="{StaticResource MonoFont}" FontSize="12"
                                               Foreground="{StaticResource AccentBrush}" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="No tags yet — add one to categorize this session."
                                   TextWrapping="Wrap"
                                   FontFamily="{StaticResource MonoFont}" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Visibility="{Binding SelectedTags.Count, Converter={StaticResource CountToVis}, ConverterParameter=empty}" />

                        <ItemsControl ItemsSource="{Binding SelectedTags}"
                                      Visibility="{Binding SelectedTags.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource IconButton}" Click="OnRemoveTag"
                                            Margin="0,0,8,8" Cursor="Hand">
                                        <Border CornerRadius="12" Background="{StaticResource AccentSoftBrush}"
                                                BorderBrush="{StaticResource AccentBorderBrush}" BorderThickness="1"
                                                Padding="11,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="13"
                                                           FontWeight="Medium" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="9"
                                                           Margin="6,1,0,0" VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Controls: Idle -->
                <Button Content="Start" Style="{StaticResource PrimaryButton}" Click="OnStart"
                        Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}" />

                <!-- Controls: Running -->
                <Grid Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Pause" Style="{StaticResource SecondaryButton}" Click="OnPause" />
                    <Button Grid.Column="2" Content="Stop" Style="{StaticResource SecondaryButton}" Click="OnStop"
                            Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBorderBrush}" />
                </Grid>

                <!-- Controls: Paused -->
                <Grid Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Resume" Style="{StaticResource PrimaryButton}" Click="OnResume" />
                    <Button Grid.Column="2" Content="Stop" Style="{StaticResource SecondaryButton}" Click="OnStop"
                            Foreground="{StaticResource DangerBrush}" BorderBrush="{StaticResource DangerBorderBrush}" />
                </Grid>

            </StackPanel>
        </Border>

        <!-- Sync toast -->
        <Border x:Name="Toast" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,18,0,0"
                CornerRadius="18" Background="{StaticResource SurfaceRaisedBrush}"
                BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                Padding="16,10" Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="ToastGlyph" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="ToastText" FontFamily="{StaticResource MonoFont}" FontSize="13"
                           FontWeight="Medium" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <Button x:Name="ToastRetry" Content="Retry" Click="OnRetry" Margin="10,0,0,0"
                        Style="{StaticResource IconButton}" Visibility="Collapsed"
                        FontFamily="{StaticResource MonoFont}" FontSize="12"
                        Foreground="{StaticResource AccentBrush}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
