<Window x:Class="TaggdWin.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" SizeToContent="Height"
        Width="340" WindowStartupLocation="CenterOwner">

    <Border Margin="10" CornerRadius="14" Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" Color="Black" />
        </Border.Effect>
        <StackPanel Margin="20">
            <TextBlock x:Name="TitleText" FontFamily="{StaticResource MonoFont}" FontSize="16"
                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,6,0,14"
                       FontFamily="{StaticResource MonoFont}" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" />
            <TextBox x:Name="ValueBox" Style="{StaticResource FieldTextBox}" />
            <Grid Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancel" Style="{StaticResource SecondaryButton}"
                        Height="40" IsCancel="True" Click="OnCancel" />
                <Button Grid.Column="2" Content="Add" Style="{StaticResource PrimaryButton}"
                        Height="40" IsDefault="True" Click="OnOk" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
