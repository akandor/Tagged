          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las actualizaciones se distribuyen desde GitHub Releases y se verifican mediante una firma. La aplicación no se distribuye a través de la Mac App Store."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les mises à jour sont fournies depuis GitHub Releases et vérifiées à l'aide d'une signature. L'application n'est pas distribuée via le Mac App Store."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli aggiornamenti vengono distribuiti tramite GitHub Releases e verificati tramite firma. L'app non è distribuita tramite il Mac App Store."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更新は GitHub Releases から配信され、署名によって検証されます。このアプリは Mac App Store を通じて配布されていません。"
