    "Sync with a self-hosted TimeTagger backend, e.g. https://timetagger.example.com. Create an API token in TimeTagger under Account → API token." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisiere mit einem selbst gehosteten TimeTagger-Backend, z. B. https://timetagger.example.com. Erstelle einen API-Token in TimeTagger unter „Konto“ → „API-Token“."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincroniza con un backend de TimeTagger autohospedado, p. ej., https://timetagger.example.com. Crea un token de la API en TimeTagger en Cuenta → Token de la API."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Synchronisez avec un backend TimeTagger auto-hébergé, par exemple https://timetagger.example.com. Créez un jeton API dans TimeTagger sous Compte → Jeton API."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincronizza con un backend TimeTagger self-hosted, ad esempio https://timetagger.example.com. Crea un token API in TimeTagger alla voce Account → Token API."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "https://timetagger.example.com など、セルフホスト型の TimeTagger バックエンドと同期します。TimeTagger の [アカウント] → [API トークン] で API トークンを作成してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "https://timetagger.example.com와 같은 자체 호스팅 TimeTagger 백엔드와 동기화하세요. TimeTagger의 계정 → API 토큰에서 API 토큰을 생성하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sincronize com um backend do TimeTagger auto-hospedado, por exemplo, https://timetagger.example.com. Crie um token da API no TimeTagger em Conta → Token da API."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "与自托管的 TimeTagger 后端同步，例如 https://timetagger.example.com。在 TimeTagger 的“账户”→“API 令牌”下创建一个 API 令牌。"
          }
        }
      }
    },
