          "stringUnit" : {
            "state" : "translated",
            "value" : "업데이트는 GitHub Releases를 통해 제공되며, 서명으로 검증됩니다. 이 앱은 Mac App Store를 통해 배포되지 않습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
