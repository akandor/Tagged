    "Tap a name to rename · swipe to delete · use Edit to reorder." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zum Umbenennen auf einen Namen tippen · zum Löschen wischen · „Bearbeiten“ zum Sortieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca un nombre para cambiarlo · desliza para eliminar · usa Editar para reordenarlas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez sur un nom pour le renommer · balayez pour supprimer · utilisez « Modifier » pour réorganiser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca un nome per rinominarlo · scorri per eliminarlo · usa Modifica per riordinarli."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "名前をタップして名前を変更 · スワイプして削除 · 「編集」で順序を変更。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이름을 탭하여 이름 변경 · 스와이프하여 삭제 · ‘편집’을 사용하여 순서 변경."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toque em um nome para renomear · deslize para excluir · use Editar para reordenar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
