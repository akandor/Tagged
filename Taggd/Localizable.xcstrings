    "The current time will be saved and the timer reset." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die aktuelle Zeit wird gespeichert und der Timer zurückgesetzt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se guardará la hora actual y se reiniciará el temporizador."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'heure actuelle sera enregistrée et le chronomètre réinitialisé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'ora corrente verrà salvata e il timer azzerato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在の時刻が保存され、タイマーがリセットされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "현재 시간이 저장되고 타이머가 재설정됩니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A hora atual será salva e o cronômetro será reiniciado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当前时间将被保存，计时器将重置。"
          }
        }
      }
    },
    "There's no paused session to resume." : {

    },
    "There's no running session to pause." : {

    },
    "These sessions are stored on your device and will not sync automatically. Tap a session — or Retry All — to upload it to your server." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Sitzung werden auf deinem Gerät gespeichert und werden nicht automatisch synchronisiert. Tippe auf eine Sitzung – oder auf „Alle erneut versuchen“ –, um sie auf deinen Server hochzuladen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estas sesiones se guardan en tu dispositivo y no se sincronizarán automáticamente. Toca una sesión —o «Reintentar todo»— para subirla a tu servidor."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces séances sont enregistrées sur votre appareil et ne se synchronisent pas automatiquement. Appuyez sur une séance — ou sur « Réessayer tout » — pour la transférer vers votre serveur."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Queste sessioni vengono salvate sul tuo dispositivo e non verranno sincronizzate automaticamente. Tocca una sessione — oppure “Riprova tutto” — per caricarla sul tuo server."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらのセッションは端末に保存されており、自動的に同期されることはありません。セッションをタップするか、「すべて再試行」をタップして、サーバーにアップロードしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 세션들은 기기에 저장되며 자동으로 동기화되지 않습니다. 세션을 탭하거나 ‘모두 다시 시도’를 탭하여 서버에 업로드하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Essas sessões ficam armazenadas no seu dispositivo e não serão sincronizadas automaticamente. Toque em uma sessão — ou em “Repetir tudo” — para enviá-la ao seu servidor."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些训练记录存储在您的设备上，不会自动同步。点击某次训练记录——或点击“全部重试”——即可将其上传至您的服务器。"
          }
        }
      }
    },
    "This removes it from the server and can't be undone here." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies entfernt ihn vom Server und kann hier nicht rückgängig gemacht werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto la elimina del servidor y no se puede deshacer aquí."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela la supprime du serveur et ne peut pas être annulé ici."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questo la rimuove dal server e non può essere annullato qui."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サーバーから削除され、ここでは元に戻せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "서버에서 제거되며 여기서는 실행을 취소할 수 없습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso a remove do servidor e não pode ser desfeito aqui."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这将从服务器中移除它，且无法在此撤销。"
          }
        }
      }
    },
